# Challenge: tidy up Danish Monarchs dataset
# Tidyverse
install.packages("tidyverse")
library(tidyverse)

# Danish Monarchs
monarchs <- read_csv2(file.choose())

# Checking dataset
glimpse(monarchs)
view(monarchs)

# Length of reign
monarchs <- monarchs %>%
  mutate(duration = End_of_Reign - Start_of_Reign)

  # Making them numeric, not characters
monarchs <- monarchs %>%
  mutate(
    Start_of_Reign = as.numeric(Start_of_Reign),
    End_of_Reign = as.numeric(End_of_Reign),
    duration = End_of_Reign - Start_of_Reign
  )

# Mean
mean(monarchs$duration, na.rm = TRUE)
  # = 19.96078 (years)

# Median
median(monarchs$duration, na.rm = TRUE)
  # = 16 (years)
